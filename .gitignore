# Dependencies
node_modules/

# Build output
dist/
build/

# Environment variables — never commit real env files
.env
.env.local
.env.*.local

# Production scripts — contain real secrets, never commit
scripts/*.prod.sh

# Prisma generated client (regenerated via `prisma generate`)
src/generated/

# Test coverage
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript cache
*.tsbuildinfo
