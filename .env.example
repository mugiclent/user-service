NODE_ENV=development
PORT=3000

# PostgreSQL — Prisma connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/katisha_users
# Required when NODE_ENV=test
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/katisha_users_test

# Redis — rate limiting and OTP TTL tracking
REDIS_URL=redis://localhost:6379

# RabbitMQ — audit logs and notification service events
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT — must be at least 32 random characters
JWT_SECRET=change_me_to_at_least_32_random_characters_here
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30

# Cookies
COOKIE_SECURE=true

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_WINDOW_SECONDS=600

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_RESET_MAX=3
RATE_LIMIT_RESET_WINDOW_SECONDS=3600
