NODE_ENV=development
PORT=3000

# PostgreSQL — Prisma connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/katisha_users
# Required when NODE_ENV=test
TEST_DATABASE_URL=postgresql://user:pass@localhost:5432/katisha_users_test

# Redis — rate limiting and OTP TTL tracking
REDIS_URL=redis://localhost:6379

# RabbitMQ — audit logs and notification service events
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT — RS256 asymmetric signing
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Store as single-line with literal \n, or use multi-line PEM directly.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=7

# Cookies
COOKIE_SECURE=true

# OTP
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=3
OTP_WINDOW_SECONDS=600

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_SECONDS=900
RATE_LIMIT_RESET_MAX=3
RATE_LIMIT_RESET_WINDOW_SECONDS=3600
