generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserType {
  passenger
  staff
}

enum UserStatus {
  active
  pending_verification
  suspended
}

enum OrgType {
  company
  cooperative
}

enum OrgStatus {
  pending
  active
  suspended
  rejected
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Org {
  id                      String    @id @default(uuid())
  name                    String    @unique @db.VarChar(200)
  slug                    String    @unique @db.VarChar(200)
  org_type                OrgType
  status                  OrgStatus @default(pending)
  tin                     String?   @unique @db.VarChar(50)
  license_number          String?   @unique @db.VarChar(100)
  contact_email           String    @db.VarChar(255)
  contact_phone           String    @db.VarChar(20)
  address                 String?   @db.VarChar(500)
  logo_url                String?
  parent_org_id           String?
  approved_by             String?   // user id of the approving Katisha Admin
  approved_at             DateTime?
  rejection_reason        String?
  cooperative_approved_at DateTime? // set by parent cooperative's Org Admin (step 1 of 2)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt
  deleted_at              DateTime?

  parent_org Org?  @relation("OrgHierarchy", fields: [parent_org_id], references: [id])
  child_orgs Org[] @relation("OrgHierarchy")
  users      User[]
  roles      Role[]

  @@map("orgs")
}

model Role {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(100)
  slug       String   @db.VarChar(100)
  org_id     String?  // null = platform-level role (katisha_admin, katisha_support, etc.)
  created_at DateTime @default(now())

  org         Org?         @relation(fields: [org_id], references: [id])
  user_roles  UserRole[]
  invitations Invitation[]

  @@unique([slug, org_id])
  @@map("roles")
}

model User {
  id                         String     @id @default(uuid())
  first_name                 String     @db.VarChar(100)
  last_name                  String     @db.VarChar(100)
  phone_number               String     @unique @db.VarChar(20)  // mandatory for all users
  phone_verified_at          DateTime?
  email                      String?    @unique @db.VarChar(255) // staff only (optional)
  email_verified_at          DateTime?
  password_hash              String?    // null for invited staff until they set a password
  user_type                  UserType
  status                     UserStatus @default(pending_verification)
  two_factor_enabled         Boolean    @default(false)
  avatar_url                 String?
  org_id                     String?    // null for passengers
  driver_license_number      String?    @db.VarChar(100)
  driver_license_verified_at DateTime?
  last_login_at              DateTime?
  created_at                 DateTime   @default(now())
  updated_at                 DateTime   @updatedAt
  deleted_at                 DateTime?

  org            Org?           @relation(fields: [org_id], references: [id])
  refresh_tokens RefreshToken[]
  otps           Otp[]
  user_roles     UserRole[]

  @@map("users")
}

model UserRole {
  user_id    String
  role_id    String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@map("user_roles")
}

model RefreshToken {
  id          String    @id @default(uuid())
  token_hash  String    @unique // SHA-256 of raw token — never store raw
  user_id     String
  device_name String?   @db.VarChar(200)
  expires_at  DateTime
  revoked_at  DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("refresh_tokens")
}

model Otp {
  id         String    @id @default(uuid())
  user_id    String
  purpose    String    @db.VarChar(30)   // phone_verification | 2fa | password_reset
  code_hash  String    // SHA-256 of the 6-digit code
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, purpose])
  @@map("otps")
}

model MediaAsset {
  id          String   @id @default(uuid())
  entity_type String   @db.VarChar(20)  // "user" | "org"
  entity_id   String
  field_name  String   @db.VarChar(50)  // "avatar" | "logo"
  filename    String   @db.VarChar(255) // UUID-based filename in SeaweedFS
  mime_type   String   @db.VarChar(100)
  size_bytes  Int
  filer_path  String   @db.VarChar(500) // e.g. /images/avatars/<uuid>.jpg
  public_url  String                    // full public URL stored in the entity field
  uploaded_by String                    // user id of the uploader
  created_at  DateTime @default(now())

  @@unique([entity_type, entity_id, field_name]) // one active asset per field
  @@index([entity_id])
  @@map("media_assets")
}

model Invitation {
  id           String    @id @default(uuid())
  email        String?   @db.VarChar(255)
  phone_number String?   @db.VarChar(20)
  first_name   String    @db.VarChar(100)
  last_name    String    @db.VarChar(100)
  role_id      String
  org_id       String?
  invited_by   String    // user id of the admin who sent it
  token_hash   String    @unique
  expires_at   DateTime
  accepted_at  DateTime?
  created_at   DateTime  @default(now())

  role Role @relation(fields: [role_id], references: [id])

  @@map("invitations")
}
